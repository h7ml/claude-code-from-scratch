{
  "1": {
    "scenario": "read-a-file",
    "expect": {
      "toolCalls": [
        "read_file"
      ],
      "toolResultsContain": [
        "hello from step one"
      ],
      "finalStopReason": "end_turn"
    }
  },
  "2": {
    "scenario": "write-a-file",
    "expect": {
      "toolCalls": [
        "write_file"
      ],
      "toolResultsContain": [
        "Successfully wrote to notes.txt"
      ],
      "files": {
        "notes.txt": "remember-this"
      },
      "finalStopReason": "end_turn"
    }
  },
  "3": {
    "scenario": "read-a-file",
    "expect": {
      "toolCalls": [
        "read_file"
      ],
      "toolResultsContain": [
        "hello from step one"
      ],
      "systemContains": "Do not propose changes to code you haven't read",
      "finalStopReason": "end_turn"
    }
  },
  "4": {
    "scenario": "resume-session",
    "expect": {
      "toolCalls": [],
      "finalStopReason": "end_turn",
      "sessionFile": ".mini-session.json",
      "resumedFirstUser": "favorite color is blue"
    }
  }
}